# ----------------------------------------------------------------------------
# Example environment variables for local development.
#
# Copy to the appropriate location and fill in real values:
# - Backend:  apps/api/.env
# - Frontend: apps/web/.env.local (or export in your shell)
#
# IMPORTANT: Never commit real secrets (API keys, tokens, JWT secrets).
# ----------------------------------------------------------------------------

# Backend (apps/api)
ANTHROPIC_API_KEY=your_anthropic_key_here
DATABASE_URL=sqlite:///./forgeos.db
JWT_SECRET_KEY=change-me-in-production

# Arize AX tracing (optional)
ARIZE_SPACE_ID=your_space_id_here
ARIZE_API_KEY=your_arize_api_key_here
ARIZE_PROJECT_NAME=forgeos

# Optional automation scripts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
LOOKBACK_HOURS=12
X_HANDLE=your_handle_here

# Frontend (apps/web)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
