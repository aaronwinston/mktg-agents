# ============================================================================
# ForgeOS Environment Configuration
# ============================================================================

# Personal mode: set FORGEOS_MODE=personal (default) for single-user operation
# Multi-tenant mode: set FORGEOS_MODE=multi_tenant for SaaS operation
FORGEOS_MODE=personal

# ============================================================================
# REQUIRED: Core LLM and Database
# ============================================================================

# Anthropic API key for LLM generations
ANTHROPIC_API_KEY=sk-ant-...

# Database URL (defaults to local SQLite)
DATABASE_URL=sqlite:///./forgeos.db

# LLM key encryption secret (used for at-rest encryption of stored credentials)
LLM_KEY_ENCRYPTION_SECRET=base64-encoded-32-byte-key

# ============================================================================
# OPTIONAL: Only needed in multi_tenant mode
# ============================================================================

# OpenAI API key (optional, for multi-runtime support)
OPENAI_API_KEY=sk-...

# LLM generation and scoring model preferences
MODEL_GENERATION=claude-opus-4-7
MODEL_SCORING=claude-haiku-4-5

# JWT secret for auth tokens (auto-generated if not provided)
JWT_SECRET_KEY=base64-encoded-secret

# Encryption key for credentials vault (auto-generated if not provided)
ENCRYPTION_KEY=base64-encoded-32-byte-key

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# OPTIONAL: Google Calendar Integration
# ============================================================================

GOOGLE_OAUTH_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_SECRET=...
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# ============================================================================
# OPTIONAL: Stripe Billing & Metering (M2)
# ============================================================================

STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# OPTIONAL: Background Jobs (Celery + Redis)
# ============================================================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# OPTIONAL: Caching (Redis)
# ============================================================================

REDIS_URL=redis://localhost:6379/1
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# ============================================================================
# OPTIONAL: Logging and Observability
# ============================================================================

LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14

# Sentry error tracking and performance monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SAMPLE_RATE=0.1

# ============================================================================
# OPTIONAL: Rate Limiting
# ============================================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_X_FORWARDED_FOR=false
RATE_LIMIT_STORAGE_URI=memory://

# Per-endpoint-category limits
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_PUBLIC=60/minute
RATE_LIMIT_INTERNAL=100/minute
RATE_LIMIT_EXPENSIVE_GLOBAL=30/minute
